{
  "name": "taskosphere-agent",
  "version": "4.0.0",
  "description": "Taskosphere Enterprise Desktop Agent",
  "main": "agent.js",
  "bin": "agent.js",
  "scripts": {
    "start": "node agent.js",
    "build": "pkg . --targets node18-win-x64 --output dist/TaskosphereAgent.exe",
    "build:linux": "pkg . --targets node18-linux-x64 --output dist/TaskosphereAgent",
    "build:mac": "pkg . --targets node18-macos-x64 --output dist/TaskosphereAgent-macos"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^4.18.2"
  },
  "devDependencies": {
    "pkg": "^5.8.1"
  },
  "pkg": {
    "assets": [
      "modules/**/*"
    ],
    "targets": ["node18-win-x64"],
    "outputPath": "dist"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
