{
  "name": "taskosphere-root",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "frontend"
  ],
  "scripts": {
    "dev": "tsx server.ts",
    "build": "npm run build --workspace=frontend && esbuild server.ts --bundle --platform=node --format=cjs --packages=external --sourcemap --outfile=dist/server.cjs",
    "start": "node dist/server.cjs"
  },
  "dependencies": {
    "express": "^5.2.1"
  },
  "devDependencies": {
    "esbuild": "^0.28.1",
    "tsx": "^4.23.1",
    "vite": "^8.1.5"
  }
}
